{
  "appId": "app.ringin.mobile",
  "appName": "RingIn",
  "webDir": "build",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": false
  },
  "ios": {
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#09090E",
      "launchShowDuration": 1500
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "directUpdate": false,
      "autoSplashscreen": false,
      "responseTimeout": 30,
      "appReadyTimeout": 10000,
      "resetWhenUpdate": false
    }
  }
}
