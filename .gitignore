/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Capacitor — generated native platform folders. We don't commit these
# because they're huge, platform-specific, and reconstructable from
# `npx cap add android` / `npx cap add ios` followed by
# `node tools/install-native-plugins.mjs` to drop in our custom plugin.
/android
/ios
.capacitor/

# Firebase Android app-registration file. Contains the Android FCM API key +
# app id — NOT a hard secret (it ships inside every APK) but the GitHub repo is
# public, so keep it local. install-native-plugins.mjs copies it from here into
# the gitignored android/app/ on every build so it survives `npx cap add android`.
/firebase/google-services.json
